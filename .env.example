# Copy to .env and fill in. Any OpenAI-compatible endpoint works
# (xf-yun MaaS, DeepSeek, OpenAI, local vLLM, ...).
LLM_BASE_URL=https://your-provider.example.com/v1
LLM_API_KEY=sk-your-key
LLM_MODEL=your-model-id

# Optional: separate judge model (defaults to LLM_MODEL)
# JUDGE_MODEL=

# Optional: run without any network/LLM — replay recorded runs only
# HINDSIGHT_OFFLINE=1
